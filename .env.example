# Database
POSTGRES_USER=shopbot
POSTGRES_PASSWORD=shopbot_secret
POSTGRES_DB=shopbot_db
DATABASE_URL=postgresql://shopbot:shopbot_secret@your-postgres-host:5432/shopbot_db

# JWT
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1

# App Settings
COMPANY_NAME=ShopBot
ENVIRONMENT=development
DEBUG=false
